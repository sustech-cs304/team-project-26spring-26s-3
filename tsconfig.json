{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "vitest/globals",
      "node"
    ]
  },
  "include": [
    "entry/src/main/ets/**/*.ts",
    "tests/**/*.ts",
    "vitest.config.ts"
  ]
}
